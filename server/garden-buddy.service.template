[Unit]
Description=Garden Buddy FastAPI Service
After=network.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__ENV_FILE__
ExecStart=__APP_DIR__/venv/bin/uvicorn src.api.app:app --host 127.0.0.1 --port __APP_PORT__
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
